<?xml version="1.0" encoding="utf-8"?>
<!-- 允许明文 HTTP（局域网/开发环境使用），正式上线后可移除 cleartext 规则 -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
